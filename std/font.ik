# Glyph geometry: each character occupies 5 column bytes, stored
# contiguously at offset (char * 5). Each column byte is read top-to-bottom
# with the least-significant bit (bit 0) at the top row, giving 8 pixel rows
# (classic glyphs use the lower 7). Renderers typically add one blank column
# of spacing between characters, for an advance of 6 columns per glyph.
# -------------------------------------------------------------------------

# Glyph width in columns (bytes per character).
@font_width() -> u8 {
    return 5
}

# Glyph height in pixels (bits per column byte).
@font_height() -> u8 {
    return 8
}

# Horizontal advance per character: glyph width plus one spacing column.
@font_advance() -> u8 {
    return 6
}

# Retrieve a single column byte of a glyph from the font.
# $char: ASCII character code (0-255)
# $col:  Column index within the glyph (0-4)
# Returns: the column bitmap byte, or 0 when $col is out of range.
@font_get_col($char: u8, $col: u8) -> u8 {
    flash str $FONT = "\x00\x00\x00\x00\x00\x3E\x5B\x4F\x5B\x3E\x3E\x6B\x4F\x6B\x3E\x1C\x3E\x7C\x3E\x1C\x18\x3C\x7E\x3C\x18\x1C\x57\x7D\x57\x1C\x1C\x5E\x7F\x5E\x1C\x00\x18\x3C\x18\x00\xFF\xE7\xC3\xE7\xFF\x00\x18\x24\x18\x00\xFF\xE7\xDB\xE7\xFF\x30\x48\x3A\x06\x0E\x26\x29\x79\x29\x26\x40\x7F\x05\x05\x07\x40\x7F\x05\x25\x3F\x5A\x3C\xE7\x3C\x5A\x7F\x3E\x1C\x1C\x08\x08\x1C\x1C\x3E\x7F\x14\x22\x7F\x22\x14\x5F\x5F\x00\x5F\x5F\x06\x09\x7F\x01\x7F\x00\x66\x89\x95\x6A\x60\x60\x60\x60\x60\x94\xA2\xFF\xA2\x94\x08\x04\x7E\x04\x08\x10\x20\x7E\x20\x10\x08\x08\x2A\x1C\x08\x08\x1C\x2A\x08\x08\x1E\x10\x10\x10\x10\x0C\x1E\x0C\x1E\x0C\x30\x38\x3E\x38\x30\x06\x0E\x3E\x0E\x06\x00\x00\x00\x00\x00\x00\x00\x5F\x00\x00\x00\x07\x00\x07\x00\x14\x7F\x14\x7F\x14\x24\x2A\x7F\x2A\x12\x23\x13\x08\x64\x62\x36\x49\x56\x20\x50\x00\x08\x07\x03\x00\x00\x1C\x22\x41\x00\x00\x41\x22\x1C\x00\x2A\x1C\x7F\x1C\x2A\x08\x08\x3E\x08\x08\x00\x80\x70\x30\x00\x08\x08\x08\x08\x08\x00\x00\x60\x60\x00\x20\x10\x08\x04\x02\x3E\x51\x49\x45\x3E\x00\x42\x7F\x40\x00\x72\x49\x49\x49\x46\x21\x41\x49\x4D\x33\x18\x14\x12\x7F\x10\x27\x45\x45\x45\x39\x3C\x4A\x49\x49\x31\x41\x21\x11\x09\x07\x36\x49\x49\x49\x36\x46\x49\x49\x29\x1E\x00\x00\x14\x00\x00\x00\x40\x34\x00\x00\x00\x08\x14\x22\x41\x14\x14\x14\x14\x14\x00\x41\x22\x14\x08\x02\x01\x59\x09\x06\x3E\x41\x5D\x59\x4E\x7C\x12\x11\x12\x7C\x7F\x49\x49\x49\x36\x3E\x41\x41\x41\x22\x7F\x41\x41\x41\x3E\x7F\x49\x49\x49\x41\x7F\x09\x09\x09\x01\x3E\x41\x41\x51\x73\x7F\x08\x08\x08\x7F\x00\x41\x7F\x41\x00\x20\x40\x41\x3F\x01\x7F\x08\x14\x22\x41\x7F\x40\x40\x40\x40\x7F\x02\x1C\x02\x7F\x7F\x04\x08\x10\x7F\x3E\x41\x41\x41\x3E\x7F\x09\x09\x09\x06\x3E\x41\x51\x21\x5E\x7F\x09\x19\x29\x46\x26\x49\x49\x49\x32\x03\x01\x7F\x01\x03\x3F\x40\x40\x40\x3F\x1F\x20\x40\x20\x1F\x3F\x40\x38\x40\x3F\x63\x14\x08\x14\x63\x03\x04\x78\x04\x03\x61\x59\x49\x4D\x43\x00\x7F\x41\x41\x41\x02\x04\x08\x10\x20\x00\x41\x41\x41\x7F\x04\x02\x01\x02\x04\x40\x40\x40\x40\x40\x00\x03\x07\x08\x00\x20\x54\x54\x78\x40\x7F\x28\x44\x44\