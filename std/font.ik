    ? $col > 4 { return 0 }

    ram mut $idx: u16 = $char
    $idx * 5 -> $idx
    $idx + $col -> $idx

    return $FONT[$idx]
}

# Copy the 5 column bytes of $char's glyph into SRAM buffer $dest.
# $dest must point to at least @font_width() (5) bytes.
@font_get_glyph($char: u8, $dest: ptr ram u8) {
    loop 0..5 -> $col {
        ram imut $b: u8 = @font_get_col($char, $col)
        $b -> *($dest + $col)
    }
}

# Render a NUL-terminated SRAM string into a column-bitmap stream in $dest.
# Each character emits 5 glyph columns followed by 1 blank spacing column
# (an advance of 6). Writing stops once $max_cols columns have been produced,
# guaranteeing $dest is never overrun.
# Returns the number of columns actually written.
@font_render($str: str ram, $dest: ptr ram u8, $max_cols: u16) -> u16 {
    ram mut $out: u16 = 0
    ram mut $i: u16 = 0
    loop * {
        ram imut $ch: u8 = *($str + $i)
        ? $ch == 0 { return $out }
        loop 0..6 -> $col {
            ? $out >= $max_cols { return $out }
            ram mut $b: u8 = 0
            ? $col < 5 {
                @font_get_col($ch, $col) -> $b
            }
            $b -> *($dest + $out)
            $out + 1 -> $out
        }
        $i + 1 -> $i
    }
    return $out
}

# Number of glyph columns a NUL-terminated string needs when rendered,
# i.e. characters * @font_advance() (5 glyph columns + 1 spacing each).
# Use this to size your own buffer, or to validate against the capacity of
# @font_render_buf below.
@font_text_cols($str: str ram) -> u16 {
    ram mut $len: u16 = 0
    loop * {
        ram imut $ch: u8 = *($str + $len)
        ? $ch == 0 { return $len * 6 }
        $len + 1 -> $len
    }
    return 0
}

# Column capacity of the internal buffer used by @font_render_buf.
# Strings longer than this (in columns) are truncated by @font_render_buf.
@font_render_capacity() -> u16 {
    return 128
}

# Convenience renderer: render $str into a library-owned SRAM buffer so the
# caller does not have to allocate or size anything. Writes the produced
# column count to *$out_cols and returns a pointer to the column stream.
#
# The buffer is a single static region shared across calls (it has no heap on
# AVR), so each call overwrites the previous result; copy the bytes out if you
# need to keep them. Output is capped at @font_render_capacity() columns.
#
#   ram mut $n: u16 = 0
#   ram ptr u8 $cols = @font_render_buf("hello world", &$n)
#   # $cols -> $n column bytes, ready to push to a display
@font_render_buf($str: str ram, $out_cols: ptr ram u16) -> ptr ram u8 {
    ram mut $scratch: u8[128] = 0   # must match @font_render_capacity()
    ram imut $n: u16 = @font_render($str, &$scratch[0], 128)
    $n -> *$out_cols
    return &$scratch[0]
}
